# Copy this file to .env and fill in real values before running docker-compose

# Set to "development" to enable /docs and /redoc (default is production = disabled)
APP_ENV=production

# Postgres
POSTGRES_PASSWORD=change-me-strong-password

# Backend
JWT_SECRET_KEY=change-me-run-openssl-rand-hex-32
ENCRYPTION_KEY=change-me-run-python-cryptography-fernet-generate-key

# CORS — comma-separated origins allowed to call the API
CORS_ORIGINS=http://localhost:3000

# Optional: OpenAI API key fallback (set per-project in UI instead)
OPENAI_API_KEY=

# Pinterest OAuth (get from Pinterest developer portal)
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=
PINTEREST_REDIRECT_URI=http://localhost:3000/pinterest/callback

# Google OAuth (get from console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
